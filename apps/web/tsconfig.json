{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],

      "@app/*": ["./app/*"],
      "@components/*": ["./components/*"],
      "@ui/*": ["./components/ui/*"],
      "@elements/*": ["./components/elements/*"],
      "@modules/*": ["./components/modules/*"],
      "@layouts/*": ["./components/layouts/*"],
      "@templates/*": ["./components/templates/*"],
      "@guards/*": ["./components/guards/*"],

      "@features/*": ["./features/*"],
      "@hooks/*": ["./hooks/*"],
      "@providers/*": ["./providers/*"],
      "@services/*": ["./services/*"],
      "@schemas/*": ["./schemas/*"],
      "@utils/*": ["./utils/*"],
      "@lib/*": ["./lib/*"],
      "@types/*": ["./types/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
